<?xml version='1.0'?>
<configuration xmlns="urn:activemq"
               xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
               xsi:schemaLocation="urn:activemq /schema/artemis-configuration.xsd">
    <core xmlns="urn:activemq:core">
        <addresses>
            <address name="myapp.queue">
                <anycast>
                    <queue name="myapp.queue"/>
                </anycast>
            </address>
            <address name="myapp.queue.RETRY">
                <anycast>
                    <queue name="myapp.queue.RETRY"/>
                </anycast>
            </address>
            <address name="myapp.queue.DLQ">
                <anycast>
                    <queue name="myapp.queue.DLQ"/>
                </anycast>
            </address>
        </addresses>
    </core>
</configuration>