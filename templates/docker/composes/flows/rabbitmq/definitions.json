{
  "rabbit_version": "3.13",
  "exchanges": [
    {
      "name": "my_exchange",
      "vhost": "/",
      "type": "direct",
      "durable": true,
      "auto_delete": false,
      "internal": false,
      "arguments": {}
    }
  ],
  "queues": [
    {
      "name": "my_queue",
      "vhost": "/",
      "durable": true,
      "auto_delete": false,
      "arguments": {}
    },
    {
      "name": "my_queue_RETRY",
      "vhost": "/",
      "durable": true,
      "auto_delete": false,
      "arguments": {}
    },
    {
      "name": "my_queue_DLT",
      "vhost": "/",
      "durable": true,
      "auto_delete": false,
      "arguments": {}
    }
  ],
  "bindings": [
    {
      "source": "my_exchange",
      "vhost": "/",
      "destination": "my_queue",
      "destination_type": "queue",
      "routing_key": "my_routing_key",
      "arguments": {}
    },
    {
      "source": "my_exchange",
      "vhost": "/",
      "destination": "my_queue_RETRY",
      "destination_type": "queue",
      "routing_key": "my_routing_key_retry",
      "arguments": {}
    },
    {
      "source": "my_exchange",
      "vhost": "/",
      "destination": "my_queue_DLT",
      "destination_type": "queue",
      "routing_key": "my_routing_key_dlt",
      "arguments": {}
    }
  ]
}